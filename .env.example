# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=iiiiibox
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/iiiiibox

# Auth
JWT_SECRET=change-me-64-char-random-secret
JWT_REFRESH_SECRET=change-me-different-64-char-random-secret

# Razorpay (get these from the Razorpay Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Set this in Razorpay Dashboard → Settings → Webhooks → Secret
# Webhook URL: https://api.iiinbox.com/payments/webhook
RAZORPAY_WEBHOOK_SECRET=change-me-webhook-secret

# MinIO (object storage for product images)
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=iiiiibox-uploads
MINIO_ENDPOINT=minio
MINIO_PORT=9000
# Public URL for images — served via cdn.iiinbox.com Caddy reverse proxy
MINIO_PUBLIC_URL=https://cdn.iiinbox.com

# Meilisearch (product search — optional; falls back to Postgres trigram if omitted)
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-search-key

# Redis (sessions + hot-path caching for published pages/categories/assets).
# Optional in the sense that the app degrades gracefully if unreachable —
# reads fall back to Postgres and sessions fall back to pure JWT verification.
REDIS_URL=redis://redis:6379

# SMTP relay (transactional emails: vendor approval, order confirmation)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@iiinbox.com

# Web app
NEXT_PUBLIC_API_URL=https://api.iiinbox.com
# Internal URL — used by Next.js server components to reach the API inside Docker network
API_INTERNAL_URL=http://api:4000
# Google Cloud API key with Maps JavaScript API, Places API, and Maps Static
# API enabled — powers the homepage editor's Map + Location Input components.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
