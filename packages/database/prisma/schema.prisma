generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "darwin-arm64", "darwin"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  ON_HOLD
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String?
  name         String
  role         UserRole  @default(CUSTOMER)
  isVerified   Boolean   @default(false)
  vendor       Vendor?
  addresses    Address[]
  cart         Cart?
  orders       Order[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vendor {
  id                    String       @id @default(cuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id])
  storeName             String
  storeSlug             String       @unique
  storeDescription      String?
  logoUrl               String?
  bannerUrl             String?
  status                VendorStatus @default(PENDING)
  rejectionReason       String?
  razorpayAccountId     String?      @unique
  razorpayAccountStatus String?
  commissionPercent     Decimal      @default(10) @db.Decimal(5, 2)
  products              Product[]
  subOrders             SubOrder[]
  payouts               Payout[]
  createdAt             DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
}

model Product {
  id          String      @id @default(cuid())
  vendorId    String
  vendor      Vendor      @relation(fields: [vendorId], references: [id])
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  title       String
  slug        String      @unique
  description String?
  images      String[]
  priceMinor  Int
  currency    String      @default("INR")
  stockQty    Int         @default(0)
  isActive    Boolean     @default(true)
  isApproved  Boolean     @default(true)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([vendorId])
  @@index([categoryId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@unique([cartId, productId])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String  @default("IN")
  phone     String
  isDefault Boolean @default(false)
  orders    Order[]
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  addressId        String
  address          Address     @relation(fields: [addressId], references: [id])
  status           OrderStatus @default(PENDING_PAYMENT)
  totalAmountMinor Int
  currency         String      @default("INR")
  subOrders        SubOrder[]
  payment          Payment?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SubOrder {
  id                 String         @id @default(cuid())
  subOrderNumber     String         @unique
  orderId            String
  order              Order          @relation(fields: [orderId], references: [id])
  vendorId           String
  vendor             Vendor         @relation(fields: [vendorId], references: [id])
  status             SubOrderStatus @default(PLACED)
  itemsSubtotalMinor Int
  commissionMinor    Int
  vendorPayoutMinor  Int
  items              OrderItem[]
  paymentSplit       PaymentSplit?
  payout             Payout?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([vendorId])
  @@index([orderId])
}

model OrderItem {
  id             String   @id @default(cuid())
  subOrderId     String
  subOrder       SubOrder @relation(fields: [subOrderId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  titleSnapshot  String
  priceMinorSnap Int
  quantity       Int
}

model Payment {
  id                 String         @id @default(cuid())
  orderId            String         @unique
  order              Order          @relation(fields: [orderId], references: [id])
  razorpayOrderId    String         @unique
  razorpayPaymentId  String?
  status             PaymentStatus  @default(CREATED)
  amountMinor        Int
  currency           String         @default("INR")
  splits             PaymentSplit[]
  rawWebhookPayload  Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model PaymentSplit {
  id                 String        @id @default(cuid())
  paymentId          String
  payment            Payment       @relation(fields: [paymentId], references: [id])
  subOrderId         String        @unique
  subOrder           SubOrder      @relation(fields: [subOrderId], references: [id])
  razorpayTransferId String?       @unique
  amountMinor        Int
  status             PaymentStatus @default(CREATED)
  createdAt          DateTime      @default(now())
}

model Payout {
  id                   String       @id @default(cuid())
  vendorId             String
  vendor               Vendor       @relation(fields: [vendorId], references: [id])
  subOrderId           String       @unique
  subOrder             SubOrder     @relation(fields: [subOrderId], references: [id])
  amountMinor          Int
  status               PayoutStatus @default(PENDING)
  razorpaySettlementId String?
  processedAt          DateTime?
  createdAt            DateTime     @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
}

model PageConfig {
  id        String   @id @default(cuid())
  page      String   @unique
  config    Json     @default("{\"components\":[]}")
  // Draft (`config`) vs live is a real split — editing/autosaving only ever
  // touches `config`. A page only goes live when its Folder is published,
  // which copies `config` -> `publishedConfig` for every page in that folder
  // at once. null = never published = not reachable on the live site at all.
  publishedConfig Json?
  updatedAt DateTime @updatedAt

  folderId   String?
  folder     Folder?  @relation("FolderPages", fields: [folderId], references: [id], onDelete: SetNull)
  rootOfFolder Folder? @relation("FolderRootPage")
}

// Mostly an admin-organizational layer, EXCEPT: a Folder with a non-null
// `subdomain` is now live-routing-relevant — see middleware.ts, which
// resolves the Host header to a folder's root page via the API instead of
// the old hardcoded slug list.
model Project {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  folders   Folder[]
}

// Arbitrary count per project — no longer fixed at 3. `subdomain` (nullable,
// globally unique) is what middleware.ts now looks up to decide which
// folder's root page serves a given Host header; a folder with `subdomain:
// null` is a plain organizational container with no live-routing meaning at
// all. rootPageId is a nullable-unique FK (not a boolean on PageConfig) so
// "at most one folder can claim a given page as its root" is DB-enforced.
model Folder {
  id         String       @id @default(cuid())
  name       String
  subdomain  String?      @unique
  projectId  String
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rootPageId String?      @unique
  rootPage   PageConfig?  @relation("FolderRootPage", fields: [rootPageId], references: [id])
  pages      PageConfig[] @relation("FolderPages")
  createdAt  DateTime     @default(now())
}

// Singleton row (always id "global") — the only site-wide, not-per-page
// settings in the app. Everything else (canvas background, header
// sticky/hide behavior, etc.) intentionally lives inside each page's own
// PageConfig.config instead.
model SiteSettings {
  id                 String   @id @default("global")
  logoUrl            String?
  logoWidth          Int      @default(120)
  logoAlign          String   @default("left")
  logoLink           String   @default("/")
  faviconUrl         String?
  faviconContentType String   @default("image/png")
  updatedAt          DateTime @updatedAt
}
