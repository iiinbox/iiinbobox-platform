generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  ON_HOLD
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String?
  name         String
  role         UserRole  @default(CUSTOMER)
  isVerified   Boolean   @default(false)
  vendor       Vendor?
  addresses    Address[]
  cart         Cart?
  orders       Order[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vendor {
  id                    String       @id @default(cuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id])
  storeName             String
  storeSlug             String       @unique
  storeDescription      String?
  logoUrl               String?
  bannerUrl             String?
  status                VendorStatus @default(PENDING)
  rejectionReason       String?
  razorpayAccountId     String?      @unique
  razorpayAccountStatus String?
  commissionPercent     Decimal      @default(10) @db.Decimal(5, 2)
  products              Product[]
  subOrders             SubOrder[]
  payouts               Payout[]
  createdAt             DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  vendorId    String
  vendor      Vendor      @relation(fields: [vendorId], references: [id])
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  title       String
  slug        String      @unique
  description String?
  images      String[]
  priceMinor  Int
  currency    String      @default("INR")
  stockQty    Int         @default(0)
  isActive    Boolean     @default(true)
  isApproved  Boolean     @default(true)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([vendorId])
  @@index([categoryId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@unique([cartId, productId])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String  @default("IN")
  phone     String
  isDefault Boolean @default(false)
  orders    Order[]
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  addressId        String
  address          Address     @relation(fields: [addressId], references: [id])
  status           OrderStatus @default(PENDING_PAYMENT)
  totalAmountMinor Int
  currency         String      @default("INR")
  subOrders        SubOrder[]
  payment          Payment?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SubOrder {
  id                 String         @id @default(cuid())
  subOrderNumber     String         @unique
  orderId            String
  order              Order          @relation(fields: [orderId], references: [id])
  vendorId           String
  vendor             Vendor         @relation(fields: [vendorId], references: [id])
  status             SubOrderStatus @default(PLACED)
  itemsSubtotalMinor Int
  commissionMinor    Int
  vendorPayoutMinor  Int
  items              OrderItem[]
  paymentSplit       PaymentSplit?
  payout             Payout?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([vendorId])
  @@index([orderId])
}

model OrderItem {
  id             String   @id @default(cuid())
  subOrderId     String
  subOrder       SubOrder @relation(fields: [subOrderId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  titleSnapshot  String
  priceMinorSnap Int
  quantity       Int
}

model Payment {
  id                 String         @id @default(cuid())
  orderId            String         @unique
  order              Order          @relation(fields: [orderId], references: [id])
  razorpayOrderId    String         @unique
  razorpayPaymentId  String?
  status             PaymentStatus  @default(CREATED)
  amountMinor        Int
  currency           String         @default("INR")
  splits             PaymentSplit[]
  rawWebhookPayload  Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model PaymentSplit {
  id                 String        @id @default(cuid())
  paymentId          String
  payment            Payment       @relation(fields: [paymentId], references: [id])
  subOrderId         String        @unique
  subOrder           SubOrder      @relation(fields: [subOrderId], references: [id])
  razorpayTransferId String?       @unique
  amountMinor        Int
  status             PaymentStatus @default(CREATED)
  createdAt          DateTime      @default(now())
}

model Payout {
  id                   String       @id @default(cuid())
  vendorId             String
  vendor               Vendor       @relation(fields: [vendorId], references: [id])
  subOrderId           String       @unique
  subOrder             SubOrder     @relation(fields: [subOrderId], references: [id])
  amountMinor          Int
  status               PayoutStatus @default(PENDING)
  razorpaySettlementId String?
  processedAt          DateTime?
  createdAt            DateTime     @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
}
