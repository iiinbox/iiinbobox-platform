PORT=4000
DATABASE_URL=postgresql://postgres:change-me@localhost:5433/iiiiibox

# Auth
JWT_SECRET=change-me-64-char-random-secret
JWT_REFRESH_SECRET=change-me-different-64-char-random-secret

# Razorpay (live keys from Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret from Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=change-me-webhook-secret

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=iiiiibox-uploads
# For local dev: http://localhost:9000 | For prod: https://cdn.iiinbox.com
MINIO_PUBLIC_URL=http://localhost:9000

# Meilisearch (optional)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@iiinbox.com
